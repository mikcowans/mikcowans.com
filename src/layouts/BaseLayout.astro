---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  schema?: object | object[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage = '/og-default.png',
  ogType = 'website',
  schema,
  noindex = false,
} = Astro.props;

const siteUrl      = 'https://mikcowans.co.uk';
const canonicalUrl = canonical ?? Astro.url.pathname;
const fullCanonical = `${siteUrl}${canonicalUrl}`;
const fullOg       = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

const schemaArray = schema
  ? Array.isArray(schema) ? schema : [schema]
  : [];
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Mik Cowans" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={fullCanonical} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="en" href={fullCanonical} />
    <link rel="alternate" hreflang="x-default" href={fullCanonical} />

    <!-- Open Graph -->
    <meta property="og:type"         content={ogType} />
    <meta property="og:url"          content={fullCanonical} />
    <meta property="og:title"        content={title} />
    <meta property="og:description"  content={description} />
    <meta property="og:image"        content={fullOg} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type"   content="image/png" />
    <meta property="og:site_name"    content="Mik Cowans" />
    <meta property="og:locale"       content="en_GB" />

    <!-- Twitter / X -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={fullOg} />

    <!-- Favicon & manifest -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fonts: self-hosted Inter — preload latin subset for LCP -->
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin.woff2" crossorigin />

    <!-- Schema.org JSON-LD -->
    {schemaArray.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <!-- Theme colour (browser chrome) -->
    <meta name="theme-color" content="#181613" />

    <slot name="head" />
  </head>
  <body>
    <!-- Skip to main content (accessibility) -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:rounded-lg focus:text-base focus:font-medium"
      style="background: var(--color-accent); color: var(--color-bg-base);"
    >
      Skip to main content
    </a>

    <slot />

    <!-- Scroll reveal — lightweight IntersectionObserver -->
    <script>
      const io = new IntersectionObserver(
        (entries) => entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            io.unobserve(e.target);
          }
        }),
        { threshold: 0.1 }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>

    <!-- Live search filter -->
    <style is:global>
      .search-hidden { display: none !important; }
    </style>
    <script is:inline>
      (function () {
        function attachSearch() {
          var input = document.getElementById('live-search');
          if (!input) return;
          input.addEventListener('input', function () {
            var q = input.value.toLowerCase().trim();
            document.querySelectorAll('[data-searchable]').forEach(function (el) {
              var text = el.dataset.searchable || '';
              var parent = el.closest('.search-result-item');
              if (!parent) return;
              var matches = !q || text.toLowerCase().includes(q);
              parent.classList.toggle('search-hidden', !matches);
            });
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', attachSearch);
        } else {
          attachSearch();
        }
      })();
    </script>
  </body>
</html>
