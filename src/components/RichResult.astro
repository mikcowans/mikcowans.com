---
import { Image } from 'astro:assets';
import headshotSrc from '../assets/headshot.jpg';
import myPhotoSrc from '../assets/my-photo.jpg';
import speakingPhotoSrc from '../assets/speaking-photo.jpg';

const cardBase = `
  flex-shrink: 0;
  background: var(--color-bg-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  display: flex;
  flex-direction: column;
`;

const headerStyle = `
  display: flex;
  align-items: center;
  padding: 9px 14px;
  border-bottom: 1px solid var(--color-border);
  flex-shrink: 0;
  font-size: 0.875rem;
  color: var(--color-text-muted);
`;

const footerStyle = `
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 9px 14px;
  border-top: 1px solid var(--color-border);
  flex-shrink: 0;
`;

const projectTiles = [
  {
    title: 'European Hotel Booking Insights',
    href: '/projects/european-hotel-booking-analysis',
    bg: 'linear-gradient(135deg, #2a2820 0%, #4a3a1a 100%)',
  },
  {
    title: 'Pension & ISA Search Analysis',
    href: '/projects/pension-isa-search-analysis',
    bg: 'linear-gradient(135deg, #1e2228 0%, #1a3a3a 100%)',
  },
];
---

<section
  aria-label="About Mik Cowans"
  class=""
  style="margin-bottom: 24px;"
>

  <div class="hero-scroll" style="
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: stretch;
    height: 340px;
    gap: 10px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-right: 1.25rem;
    width: calc(100vw - max(1.25rem, calc((100vw - 840px) / 2 + 1.25rem)));
  ">

    <!-- ── Card 1: Photo collage ─────────────────────── -->
    <article style={`${cardBase} flex-shrink:0; width:min(600px, calc(100vw - 60px)); height:100%; scroll-snap-align:start;`}>
      <div style="display:flex; flex:1; min-height:0; overflow:hidden; gap:2px; background:var(--color-bg-base);">
        <!-- Main big photo -->
        <div style="flex:0 0 58%; position:relative; overflow:hidden;">
          <Image src={headshotSrc} alt="Mik Cowans" loading="eager" fetchpriority="high" width={700} sizes="(max-width: 660px) calc(58vw - 35px), 348px" class="hero-photo"
            style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center top; display:block; filter:sepia(50%); transition:filter 0.3s ease;" />
        </div>
        <!-- Two smaller stacked tiles -->
        <div style="flex:1; display:flex; flex-direction:column; gap:2px;">
          <div style="flex:1; position:relative; overflow:hidden;">
            <Image src={myPhotoSrc} alt="My dog disapproving if she spots bad work" loading="lazy" width={280} sizes="(max-width: 660px) calc(21vw - 13px), 126px" class="hero-photo"
              style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center 45%; display:block; filter:sepia(50%); transition:filter 0.3s ease;" />
          </div>
          <div style="flex:1; position:relative; overflow:hidden;">
            <Image src={speakingPhotoSrc} alt="Speaking on stage" loading="lazy" width={500} sizes="(max-width: 660px) calc(21vw - 13px), 126px" class="hero-photo"
              style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center 60%; display:block; filter:sepia(50%); transition:filter 0.3s ease; transform:scale(2.8); transform-origin:center 45%;" />
          </div>
        </div>
      </div>
    </article>

    <!-- ── Card 2: About Mik (full height) ─────────────────── -->
    <article style={`${cardBase} flex-shrink:0; width:310px; height:100%; scroll-snap-align:start;`}>
      <div style={headerStyle}>About Mik</div>
      <div style="flex:1; padding:14px 18px; display:flex; flex-direction:column; justify-content:center;">
        <p style="font-size:1.075rem; line-height:1.65; margin:0; color:#fff; font-weight:400;">
          SEO specialist who's spent almost 20 years scaling organic search for global B2C and B2B brands. I treat websites as products: structured experimentation, technical depth, and AI tooling that ships. Based in Scotland, working globally.
        </p>
      </div>
    </article>

    <!-- ── Stacked column: LinkedIn + CV ─────────────────── -->
    <div style="
      flex-shrink: 0;
      height: 100%;
      display: flex;
      flex-direction: column;
      gap: 10px;
      flex-shrink: 0;
      scroll-snap-align: start;
    ">

      <!-- LinkedIn tile -->
      <a
        href="https://www.linkedin.com/in/mikcowans/"
        target="_blank"
        rel="noopener noreferrer"
        style="
          width: 165px;
          height: 165px;
          flex-shrink: 0;
          border-radius: var(--radius-lg);
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
          gap: 10px;
          background: var(--color-bg-surface);
          border: 1px solid var(--color-border);
          text-decoration: none;
        "
        class="cta-tile"
        aria-label="Connect on LinkedIn"
      >
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" style="filter: drop-shadow(0 0 6px rgba(232, 150, 58, 0.5));" aria-hidden="true">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
          <rect x="2" y="9" width="4" height="12"/>
          <circle cx="4" cy="4" r="2"/>
        </svg>
        <p style="margin:0; font-size:0.875rem; font-weight:500; color:#fff; letter-spacing:0.02em;">LinkedIn</p>
      </a>

      <!-- CV download tile -->
      <div
        class="cv-tile"
        style="
          width: 165px;
          height: 165px;
          flex-shrink: 0;
          border-radius: var(--radius-lg);
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
          gap: 10px;
          background: var(--color-bg-surface);
          border: 1px solid var(--color-border);
          position: relative;
        "
        aria-label="CV coming soon"
      >
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="12" y1="12" x2="12" y2="18"/>
          <polyline points="9 15 12 18 15 15"/>
        </svg>
        <p style="margin:0; font-size:0.875rem; font-weight:500; color:var(--color-text-muted); letter-spacing:0.02em;">Download CV</p>
        <span style="font-size:0.7rem; color:var(--color-accent); letter-spacing:0.05em; text-transform:uppercase;">Coming soon</span>
      </div>

    </div>

    <!-- ── Card 3: Beyond the work ─────────────────────── -->
    <article style={`${cardBase} flex-shrink:0; width:310px; height:100%; scroll-snap-align:start; position:relative;`}>
      <ul style="flex:1; margin:0; padding:16px 14px; list-style:none; display:flex; flex-direction:column; justify-content:space-around;">
        <li style="display:flex; align-items:center; gap:12px;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0; color:var(--color-text-muted);" aria-hidden="true"><path d="M12 3L2 12h2.5V20H9v-5h6v5h5.5V12H23L12 3z"/></svg>
          <div><p style="margin:0; font-size:1rem; font-weight:500; color:var(--color-text-primary); line-height:1.2;">Self-build on a hill</p><p style="margin:0; font-size:0.875rem; color:var(--color-text-muted); line-height:1.35;">Scottish countryside, still adding to it</p></div>
        </li>
        <li style="display:flex; align-items:center; gap:12px;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0; color:var(--color-text-muted);" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          <div><p style="margin:0; font-size:1rem; font-weight:500; color:var(--color-text-primary); line-height:1.2;">Solar min/maxer</p><p style="margin:0; font-size:0.875rem; color:var(--color-text-muted); line-height:1.35;">Treating the roof like an RPG build</p></div>
        </li>
        <li style="display:flex; align-items:center; gap:12px;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0; color:var(--color-text-muted);" aria-hidden="true"><path d="M17 8C8 10 5.9 16.17 3.82 20.82 5.8 20.4 7.56 19.5 9 18c0 0 4 3 8 0 4.08-3.08 5-8 5-13-4 2-7 2-11 3 1.38-1.64 3-3.58 6-5z"/></svg>
          <div><p style="margin:0; font-size:1rem; font-weight:500; color:var(--color-text-primary); line-height:1.2;">Failed gardener</p><p style="margin:0; font-size:0.875rem; color:var(--color-text-muted); line-height:1.35;">Plants keep dying, I keep trying</p></div>
        </li>
        <li style="display:flex; align-items:center; gap:12px;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0; color:var(--color-text-muted);" aria-hidden="true"><path d="M20.57 14.86L22 13.43 20.57 12 17 15.57 8.43 7 12 3.43 10.57 2 9.14 3.43 7.71 2 5.57 4.14 4.14 2.71 2.71 4.14l1.43 1.43L2 7.71l1.43 1.43L2 10.57 3.43 12 7 8.43 15.57 17 12 20.57 13.43 22l1.43-1.43L16.29 22l2.14-2.14 1.43 1.43 1.43-1.43-1.43-1.43L22 16.29z"/></svg>
          <div><p style="margin:0; font-size:1rem; font-weight:500; color:var(--color-text-primary); line-height:1.2;">Home gym, qualified PT</p><p style="margin:0; font-size:0.875rem; color:var(--color-text-muted); line-height:1.35;">The other thing I optimise</p></div>
        </li>
        <li style="display:flex; align-items:center; gap:12px;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0; color:var(--color-text-muted);" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
          <div><p style="margin:0; font-size:1rem; font-weight:500; color:var(--color-text-primary); line-height:1.2;">Corgi dad</p><p style="margin:0; font-size:0.875rem; color:var(--color-text-muted); line-height:1.35;">She runs the house</p></div>
        </li>
      </ul>
      <img src="/corgi.svg" alt="" aria-hidden="true" class="corgi-peek" width="110" />
    </article>


  </div>

  <script>
    const hasHover = window.matchMedia('(hover: hover)').matches;

    document.querySelectorAll<HTMLElement>('.corgi-peek').forEach((corgi) => {
      const article = corgi.closest('article');
      if (!article) return;

      if (hasHover) {
        article.addEventListener('mouseenter', () => {
          corgi.classList.remove('is-dropping');
          void corgi.offsetWidth;
          corgi.classList.add('is-jumping');
        });
        article.addEventListener('mouseleave', () => {
          corgi.classList.remove('is-jumping');
          void corgi.offsetWidth;
          corgi.classList.add('is-dropping');
        });
      } else {
        article.addEventListener('click', () => {
          const up = corgi.classList.contains('is-jumping');
          corgi.classList.remove('is-jumping', 'is-dropping');
          void corgi.offsetWidth;
          corgi.classList.add(up ? 'is-dropping' : 'is-jumping');
        });
      }
    });
  </script>

  <style>
    section[aria-label="About Mik Cowans"] div::-webkit-scrollbar { display: none; }
    .hero-photo:hover { filter: sepia(0%) !important; }
    .cta-tile { transition: border-color 0.2s ease, background 0.2s ease; }
    .cta-tile:hover { border-color: var(--color-accent) !important; background: var(--color-accent-tint) !important; }

    @media (max-width: 768px) {
      .hero-scroll { height: 300px !important; }
      .cta-tile, .cv-tile { width: 145px !important; height: 145px !important; }
    }

    .corgi-peek {
      position: absolute;
      bottom: -58px;
      right: 12px;
      width: 110px;
      transform: scaleX(-1) translateY(0) rotate(0deg);
      pointer-events: none;
    }
    .corgi-peek.is-jumping {
      animation: corgi-jump 0.5s ease forwards;
    }
    .corgi-peek.is-dropping {
      animation: corgi-drop 0.45s ease forwards;
    }
    @keyframes corgi-jump {
      0%   { transform: scaleX(-1) translateY(0px)   rotate(0deg);  }
      30%  { transform: scaleX(-1) translateY(-74px) rotate(15deg); }
      55%  { transform: scaleX(-1) translateY(-50px) rotate(10deg); }
      72%  { transform: scaleX(-1) translateY(-63px) rotate(12deg); }
      86%  { transform: scaleX(-1) translateY(-56px) rotate(11deg); }
      100% { transform: scaleX(-1) translateY(-60px) rotate(11deg); }
    }
    @keyframes corgi-drop {
      0%   { transform: scaleX(-1) translateY(-60px) rotate(11deg); }
      25%  { transform: scaleX(-1) translateY(-6px)  rotate(4deg);  }
      45%  { transform: scaleX(-1) translateY(-20px) rotate(6deg);  }
      65%  { transform: scaleX(-1) translateY(-5px)  rotate(2deg);  }
      100% { transform: scaleX(-1) translateY(0px)   rotate(0deg);  }
    }
@media (prefers-reduced-motion: reduce) {
      .corgi-peek.is-jumping  { animation: none; transform: scaleX(-1) translateY(-84px); }
      .corgi-peek.is-dropping { animation: none; transform: scaleX(-1) translateY(0px);   }
    }
  </style>
</section>
